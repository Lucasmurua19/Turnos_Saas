# ─── Secretos ─────────────────────────────────────────────────────
SECRET_KEY=cambia-esto-en-produccion-usa-openssl-rand-hex-32

# ─── Base de datos ────────────────────────────────────────────────
POSTGRES_USER=turnos
POSTGRES_PASSWORD=turnos_secret
POSTGRES_DB=turnos_db

# ─── Email ────────────────────────────────────────────────────────
# Para producción con SendGrid:
# SENDGRID_API_KEY=SG.xxxxxxxxxx
# EMAIL_MOCK_MODE=false

# Para desarrollo (mock, no envía emails reales):
EMAIL_MOCK_MODE=true
EMAIL_FROM=noreply@turnossaas.com

# Para SMTP propio:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu@gmail.com
# SMTP_PASS=app-password

# ─── JWT ──────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=60
